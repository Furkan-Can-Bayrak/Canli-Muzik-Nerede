// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  CAFE
  BAND
}

enum MediaType {
  IMAGE
  VIDEO
}

enum EventStatus {
  DRAFT
  PUBLISHED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customerProfile CustomerProfile?
  cafeProfile     CafeProfile?
  bandProfile     BandProfile?

  sentMessages Message[] @relation("MessageSender")

  conversationsAsCafe Conversation[] @relation("ConversationCafe")
  conversationsAsBand Conversation[] @relation("ConversationBand")
}

model CustomerProfile {
  userId      String  @id
  displayName String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CafeProfile {
  userId      String  @id
  name        String
  provinceId  String
  districtId  String?
  address     String
  latitude    Float?
  longitude   Float?
  phone       String?
  description String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  province Province  @relation(fields: [provinceId], references: [id], onDelete: Restrict)
  district District? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  events   Event[]
}

model BandProfile {
  userId      String  @id
  bandName    String
  memberCount Int
  phone       String
  basePrice   Int
  description String?

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provinces BandProvince[]
  districts BandDistrict[]
  genres    BandGenre[]
  media     BandMedia[]

  events Event[]
}

model Province {
  id        String @id @default(uuid())
  plateCode String @unique
  name      String @unique

  districts District[]
  cafes     CafeProfile[]
  bands     BandProvince[]
  events    Event[]
}

model District {
  id         String @id @default(uuid())
  provinceId String
  name       String

  province Province      @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  cafes    CafeProfile[]
  events   Event[]
  bands    BandDistrict[]

  @@unique([provinceId, name])
  @@index([provinceId])
}

model Genre {
  id   String @id @default(uuid())
  name String @unique

  bands BandGenre[]
}

model BandProvince {
  bandId     String
  provinceId String

  band     BandProfile @relation(fields: [bandId], references: [userId], onDelete: Cascade)
  province Province    @relation(fields: [provinceId], references: [id], onDelete: Cascade)

  @@id([bandId, provinceId])
  @@index([provinceId])
}

model BandDistrict {
  bandId     String
  districtId String

  band     BandProfile @relation(fields: [bandId], references: [userId], onDelete: Cascade)
  district District    @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@id([bandId, districtId])
  @@index([districtId])
}

model BandGenre {
  bandId  String
  genreId String

  band  BandProfile @relation(fields: [bandId], references: [userId], onDelete: Cascade)
  genre Genre       @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([bandId, genreId])
  @@index([genreId])
}

model BandMedia {
  id        String    @id @default(uuid())
  bandId    String
  type      MediaType
  url       String
  createdAt DateTime  @default(now())

  band BandProfile @relation(fields: [bandId], references: [userId], onDelete: Cascade)

  @@index([bandId])
}

model Event {
  id          String      @id @default(uuid())
  cafeId      String
  provinceId  String
  districtId  String?
  address     String
  title       String?
  description String?
  startAt     DateTime?
  endAt       DateTime?
  posterUrl   String?
  price       Int?
  bandId      String?
  status      EventStatus @default(PUBLISHED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  cafe     CafeProfile  @relation(fields: [cafeId], references: [userId], onDelete: Cascade)
  province Province     @relation(fields: [provinceId], references: [id], onDelete: Restrict)
  district District?    @relation(fields: [districtId], references: [id], onDelete: SetNull)
  band     BandProfile? @relation(fields: [bandId], references: [userId], onDelete: SetNull)

  @@index([provinceId])
  @@index([districtId])
  @@index([cafeId])
  @@index([bandId])
  @@index([startAt])
  @@index([status])
}

model Conversation {
  id            String   @id @default(uuid())
  cafeUserId    String
  bandUserId    String
  createdAt     DateTime @default(now())
  lastMessageAt DateTime @default(now())

  cafeUser User @relation("ConversationCafe", fields: [cafeUserId], references: [id], onDelete: Cascade)
  bandUser User @relation("ConversationBand", fields: [bandUserId], references: [id], onDelete: Cascade)

  messages Message[]

  @@unique([cafeUserId, bandUserId])
  @@index([lastMessageAt])
}

model Message {
  id             String    @id @default(uuid())
  conversationId String
  senderUserId   String
  body           String
  createdAt      DateTime  @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
}
